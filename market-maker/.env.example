# ============================================================================
# Octarine Market Maker Bot - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env files with real credentials to git!
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED: Connection Settings
# ----------------------------------------------------------------------------

# Your market maker wallet's private key (64 hex chars with 0x prefix)
# SECURITY: This grants access to your funds. Keep it secret!
PRIVATE_KEY=0x...

# Your market maker's public wallet address (42 chars with 0x prefix)
MARKET_MAKER_ADDRESS=0x...

# Octarine API key for authenticated endpoints
# Get yours from: https://mysticfinance.xyz/developers
MARKET_MAKER_API_KEY=your-api-key-here

# ----------------------------------------------------------------------------
# OPTIONAL: Network Settings
# ----------------------------------------------------------------------------

# Base URL for Octarine API (default: production)
API_BASE_URL=https://api.mysticfinance.xyz

# RPC URL for blockchain connection (default: Plume mainnet)
# Use your own RPC for better reliability (Alchemy, Infura, etc.)
RPC_URL=https://rpc.plumenetwork.xyz

# Supported chain IDs (comma-separated)
# Default: 98866 (Plume mainnet)
SUPPORTED_CHAINS=98866

# ----------------------------------------------------------------------------
# OPTIONAL: Trading Strategy
# ----------------------------------------------------------------------------

# Price spread for bidding (0.98 = 2% profit margin)
# Lower = more competitive, Higher = more profit
PRICE_SPREAD=0.98

# Minimum bid amount in wei (prevents dust transactions)
MIN_BID_AMOUNT_WEI=1000000000000000000

# Accepted token addresses (comma-separated, or '*' for all)
# Example: 0xA0b86a33E6441e5D71E7f5d7425E3b4Ee52B8c6c,0x... 
# WARNING: '*' accepts all tokens - only use in testing!
ACCEPTED_TOKENS=*

# Blacklisted token addresses (never trade these)
BLACKLISTED_TOKENS=

# Auto-approve tokens for exchange proxy (true/false)
AUTO_APPROVE_TOKENS=true

# ----------------------------------------------------------------------------
# OPTIONAL: Liquidation Settings
# ----------------------------------------------------------------------------

# Maximum portion of debt to liquidate (0.8 = 80% max)
LIQUIDATION_MAX_RATIO=0.8

# Minimum health factor to consider liquidating (< 1.0)
LIQUIDATION_MIN_HEALTH_FACTOR=1.0

# Minimum profit margin for liquidations (as percentage)
LIQUIDATION_MIN_PROFIT=5

# Maximum gas price for liquidation transactions (gwei)
LIQUIDATION_MAX_GAS_GWEI=100

# Gas speed for liquidations: slow, standard, fast, urgent
LIQUIDATION_GAS_SPEED=fast

# Bid expiry time for liquidation orders (minutes)
LIQUIDATION_BID_EXPIRY_MIN=20

# ----------------------------------------------------------------------------
# OPTIONAL: Bidding Settings
# ----------------------------------------------------------------------------

# Maximum gas price for bidding transactions (gwei)
BIDDING_MAX_GAS_GWEI=50

# Gas speed for bidding: slow, standard, fast, urgent
BIDDING_GAS_SPEED=standard

# Bid expiry time for redemption orders (minutes)
BIDDING_BID_EXPIRY_MIN=60

# ----------------------------------------------------------------------------
# OPTIONAL: Monitoring & Timing
# ----------------------------------------------------------------------------

# How often to poll for new RFQ requests (milliseconds)
BIDDING_POLL_INTERVAL_MS=5000

# How often to check for liquidation opportunities (milliseconds)
LIQUIDATION_POLL_INTERVAL_MS=10000

# Maximum number of tracked requests before cleanup
MAX_TRACKED_REQUESTS=1000

# Health check reporting interval (milliseconds)
HEALTH_CHECK_INTERVAL_MS=60000

# ----------------------------------------------------------------------------
# OPTIONAL: Risk Management
# ----------------------------------------------------------------------------

# Maximum position size in USD (0 = unlimited)
MAX_POSITION_USD=0

# Maximum total exposure in USD (0 = unlimited)
MAX_TOTAL_EXPOSURE_USD=0

# Require manual confirmation for transactions above this threshold (USD)
MANUAL_CONFIRM_THRESHOLD_USD=100000

# ----------------------------------------------------------------------------
# OPTIONAL: Debugging & Development
# ----------------------------------------------------------------------------

# Log level: 0=SILENT, 1=ERROR, 2=WARN, 3=INFO, 4=DEBUG, 5=TRACE
LOG_LEVEL=3

# Enable verbose API logging (may expose sensitive data!)
DEBUG_API=false

# Node environment
NODE_ENV=production
