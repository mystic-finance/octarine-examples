# ============================================================================
# Octarine User App - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# ============================================================================

# ----------------------------------------------------------------------------
# API Configuration
# ----------------------------------------------------------------------------

# Base URL for Octarine API
# Production: https://api.mysticfinance.xyz
# Staging: https://staging-api.mysticfinance.xyz
VITE_API_URL=https://api.mysticfinance.xyz

# ----------------------------------------------------------------------------
# Blockchain Configuration
# ----------------------------------------------------------------------------

# Default chain ID
VITE_DEFAULT_CHAIN_ID=98866

# Chain name for display
VITE_CHAIN_NAME=Plume

# RPC URL for read operations
VITE_RPC_URL=https://rpc.plumenetwork.xyz

# ----------------------------------------------------------------------------
# App Configuration
# ----------------------------------------------------------------------------

# App name
VITE_APP_NAME=Octarine Swap

# App version
VITE_APP_VERSION=1.0.0

# Enable debug logging
VITE_DEBUG=false
